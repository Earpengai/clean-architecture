{
  "ConnectionStrings": {
    "Database": "Host=postgres;Port=5432;Database=clean-architecture;Username=postgres;Password=postgres;Include Error Detail=true"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "ServerUrl": "http://seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "Secret": "super-duper-secret-value-that-should-be-in-user-secrets",
    "Issuer": "clean-architecture",
    "Audience": "developers",
    "ExpirationInMinutes": 60
  },
  "AdminSettings": {
    "Email": "admin@saas.com",
    "Password": "Admin123!"
  },
  "Smtp": {
    "Host": "mailhog",
    "Port": 1025,
    "EnableSsl": false,
    "SenderEmail": "noreply@clean-architecture.local",
    "SenderName": "Clean Architecture App"
  },
  "FrontendUrl": "http://localhost:5173",
  "Client": {
    "BaseUrl": "http://localhost:5000/api"
  },
  "Bakong": {
    "BaseUrl": "https://sit-api-bakong.nbc.gov.kh",
    "Email": "",
    "Token": "",
    "BakongAccountId": ""
  }
}
